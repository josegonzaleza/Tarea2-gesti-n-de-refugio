@model Tarea2.Models.AnimalRecord
@{
    ViewBag.Title = "Expediente";
    Layout = "~/Views/Shared/_Layout.cshtml";

    if (Model.Rescatista == null) { Model.Rescatista = new Tarea2.Models.RescuerInfo(); }
    if (Model.Tratamientos == null) { Model.Tratamientos = new System.Collections.Generic.List<Tarea2.Models.Treatment>(); }

    var allowed = new[] { "Perro", "Gato", "Roedor", "Conejo" };
}

<div class="container">
    <div class="card">
        <h1>Expediente @Model.Expediente</h1>
        <p class="sub">Fecha ingreso: @Model.FechaIngreso.ToString("yyyy-MM-dd") · Registrado por: @Model.RegistradoPor</p>

        <div id="saveMsg" class="msg" style="display:none;"></div>

        <form id="frmExpediente">
            @Html.AntiForgeryToken()

            @Html.HiddenFor(m => m.Id)
            @Html.HiddenFor(m => m.Expediente)
            @Html.HiddenFor(m => m.FechaIngreso)
            @Html.HiddenFor(m => m.RegistradoPor)

            <div class="grid">
                <div class="field"><label>Nombre</label>@Html.TextBoxFor(m => m.Nombre)</div>

                <div class="field">
                    <label>Especie</label>
                    <select name="Especie">
                        <option value="">Seleccione...</option>
                        @foreach (var s in allowed)
                        {
                            <option value="@s" @(Model.Especie == s ? "selected" : "")>@s</option>
                        }
                    </select>
                </div>

                <div class="field"><label>Raza</label>@Html.TextBoxFor(m => m.Raza)</div>
                <div class="field"><label>Edad aproximada</label>@Html.TextBoxFor(m => m.EdadAprox)</div>
                <div class="field"><label>Sexo</label>@Html.TextBoxFor(m => m.Sexo)</div>
                <div class="field"><label>Color</label>@Html.TextBoxFor(m => m.Color)</div>

                <div class="field"><label>Motivo ingreso</label>@Html.TextBoxFor(m => m.MotivoIngreso)</div>
                <div class="field"><label>Temperamento</label>@Html.TextBoxFor(m => m.Temperamento)</div>
                <div class="field"><label>Necesidades médicas</label>@Html.TextBoxFor(m => m.NecesidadesMedicas)</div>
                <div class="field"><label>Historial vacunas</label>@Html.TextBoxFor(m => m.HistorialVacunas)</div>

                <div class="field" style="grid-column:1/-1;">
                    <label>Descripción del estado de salud al ingreso</label>
                    <textarea name="EstadoSaludIngreso">@Model.EstadoSaludIngreso</textarea>
                </div>

                <div class="field"><label>Rescatista nombre</label>@Html.TextBoxFor(m => m.Rescatista.FullName)</div>
                <div class="field"><label>Rescatista teléfono</label>@Html.TextBoxFor(m => m.Rescatista.Phone)</div>
                <div class="field"><label>Rescatista correo</label>@Html.TextBoxFor(m => m.Rescatista.Email)</div>
            </div>

            <div class="actions">
                <button class="btn primary" type="submit">Guardar</button>
                <a class="btn" href="@Url.Action("List","Animals")">Volver</a>
            </div>
        </form>

        <hr />

        <h1 style="font-size:18px;margin-top:0;">Tratamientos</h1>
        <p class="sub">Presione el boton modificar o agregar tratamiento según lo requiera.</p>

        <table class="table">
            <thead>
                <tr><th>Fecha</th><th>Tipo</th><th>Medicamento</th><th>Dosis</th><th>Cuidador</th><th></th></tr>
            </thead>
            <tbody>
                @if (Model.Tratamientos.Count == 0)
                {
                    <tr><td colspan="6">Sin tratamientos registrados.</td></tr>
                }
                else
                {
                    foreach (var t in Model.Tratamientos)
                    {
                        <tr>
                            <td>@t.Date.ToString("yyyy-MM-dd")</td>
                            <td>@t.Type</td>
                            <td>@t.MedicineName</td>
                            <td>@t.Dose</td>
                            <td>@t.CaregiverEmail</td>
                            <td style="text-align:right;">
                                <a class="btn" href="@Url.Action("Edit","Treatments", new { animalId = Model.Id, treatmentId = t.Id })">Modificar</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="actions">
            <a class="btn primary" href="@Url.Action("Add","Treatments", new { animalId = Model.Id })">Agregar Tratamiento</a>
        </div>
    </div>
</div>

@section scripts{
    <script>
function showSaveMsg(text, ok){
  var $m = $("#saveMsg");
  $m.text(text).show();
  $m.css("border-color", ok ? "rgba(34,197,94,.35)" : "rgba(239,68,68,.30)");
  $m.css("background", ok ? "rgba(34,197,94,.08)" : "rgba(239,68,68,.08)");
  $m.css("color", ok ? "#166534" : "#7f1d1d");
}

$("#frmExpediente").on("submit", function(e){
  e.preventDefault();
  $.ajax({
    url: "@Url.Action("SaveJson","Animals")",
    method: "POST",
    data: $(this).serialize(),
    success: function(r){
      if(r && r.ok) showSaveMsg("Expediente guardado correctamente.", true);
      else showSaveMsg((r && r.msg) ? r.msg : "No se pudo guardar.", false);
    },
    error: function(){
      showSaveMsg("Error servidor guardando expediente.", false);
    }
  });
});
    </script>
}