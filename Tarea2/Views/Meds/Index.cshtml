@{
    ViewBag.Title = "Medicamentos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="card">
        <h1>Mantenimiento de Medicamentos</h1>
        <p class="sub">Estos alimentan la lista de tratamientos.</p>

        <div id="mMsg" class="msg" style="display:none;"></div>

        <form id="frmAddMed">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="field" style="flex:1; min-width:240px;">
                    <label>Nuevo medicamento</label>
                    <input id="medName" placeholder="Nuevo medicamento..." />
                </div>
                <div style="margin-top:22px;">
                    <button class="btn primary" type="submit">Agregar</button>
                </div>
            </div>
        </form>

        <div class="table-wrap">
            <table class="table" id="tblMeds">
                <thead>
                    <tr>
                        <th class="col-id">ID</th>
                        <th>Nombre</th>
                        <th class="td-actions">Acción</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <div class="actions">
            <a class="btn" href="@Url.Action("Index","Dashboard")">Volver</a>
        </div>
    </div>
</div>

@section scripts{
    <script>
function showMMsg(t){ $("#mMsg").text(t).show(); }
function token(){ return $("input[name='__RequestVerificationToken']").val(); }

function loadMeds(){
  $.get("@Url.Action("ListJson","Meds")", { all: true }, function(list){
    var $tb = $("#tblMeds tbody");
    $tb.empty();

    if(!list || list.length === 0){
      $tb.append("<tr><td colspan='3'>Sin medicamentos.</td></tr>");
      return;
    }

    list.forEach(function(m){
      var id = (m.code || m.id || "");
      var name = (m.name || "");

      var btn = "<button class='btn' type='button' onclick=\"del('"+ (m.id || "") +"')\">Eliminar</button>";

      $tb.append(
        "<tr>" +
          "<td class='col-id'><span class='pill'>"+ escapeHtml(id) +"</span></td>" +
          "<td>"+ escapeHtml(name) +"</td>" +
          "<td class='td-actions'>"+ btn +"</td>" +
        "</tr>"
      );
    });
  });
}

function escapeHtml(s){
  return (s || "")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"&quot;")
    .replaceAll("'","&#39;");
}

$("#frmAddMed").on("submit", function(e){
  e.preventDefault();
  $.ajax({
    url: "@Url.Action("AddJson","Meds")",
    method: "POST",
    data: { __RequestVerificationToken: token(), name: $("#medName").val() },
    success: function(r){
      if(r && r.ok){
        $("#medName").val("");
        loadMeds();
      } else showMMsg((r && r.msg) ? r.msg : "No se pudo agregar.");
    },
    error: function(){ showMMsg("Error servidor."); }
  });
});

function del(id){
  $.ajax({
    url: "@Url.Action("DeleteJson","Meds")",
    method: "POST",
    data: { __RequestVerificationToken: token(), id: id },
    success: function(r){
      if(r && r.ok) loadMeds();
      else showMMsg((r && r.msg) ? r.msg : "No se pudo eliminar.");
    },
    error: function(){ showMMsg("Error servidor."); }
  });
}

loadMeds();
    </script>
}