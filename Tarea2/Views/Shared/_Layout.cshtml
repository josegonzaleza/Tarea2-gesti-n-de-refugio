@{
    var title = (ViewBag.Title ?? "Tarea 2") + " - Tarea2";
    var user = Session["user"] as Tarea2.Models.UserSession;
    var role = (user != null ? (user.Role ?? "") : "");
    bool isAdmin = role.Equals("Admin", System.StringComparison.OrdinalIgnoreCase);
}

<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <link rel="stylesheet" href="@Url.Content("~/Content/site.css")?v=@DateTime.Now.Ticks" />
</head>
<body>
    <header class="topbar">
        <div class="topbar__inner">
            <div class="brand">
                <span class="brand__dot"></span>
                <span class="brand__text">Tarea 2 · Refugio</span>
            </div>

            <nav class="nav">
                <a class="nav__link" href="@Url.Action("Index","Dashboard")">Dashboard</a>
                <a class="nav__link" href="@Url.Action("List","Animals")">Animales</a>

                @if (isAdmin)
                {
                    <a class="nav__link" href="@Url.Action("Register","Animals", new { step = 1 })">Registrar</a>
                    <a class="nav__link" href="@Url.Action("Index","Meds")">Medicamentos</a>
                }

                <a class="nav__link nav__link--danger" href="@Url.Action("Logout","Auth")">Salir</a>
            </nav>
        </div>
    </header>

    <main class="page">
        @RenderBody()
    </main>

    @Scripts.Render("~/bundles/jquery")
    @RenderSection("scripts", required: false)
</body>
</html>