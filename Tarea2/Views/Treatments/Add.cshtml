@{
    ViewBag.Title = "Agregar Tratamiento";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var meds = (System.Collections.Generic.List<Tarea2.Models.MedItem>)ViewBag.Meds;
    var animalId = (string)ViewBag.AnimalId;
}

<div class="container">
    <div class="card">
        <h1>Agregar Tratamiento</h1>
        <p class="sub">Fecha obligatoria (no futura) · Tipo/Medicamento/Dosis obligatorios.</p>

        <div id="tMsg" class="msg" style="display:none;"></div>

        <form id="frmAddT">
            @Html.AntiForgeryToken()
            <input type="hidden" name="animalId" value="@animalId" />

            <div class="grid">
                <div class="field">
                    <label>Fecha (obligatorio)</label>
                    <input type="date" name="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>

                <div class="field">
                    <label>Tipo (obligatorio)</label>
                    <select name="type">
                        <option value="">Seleccione...</option>
                        <option value="Medicamento">Medicamento</option>
                        <option value="Cirugía">Cirugía</option>
                        <option value="Vacuna">Vacuna</option>
                        <option value="Curación">Curación</option>
                    </select>
                </div>

                <div class="field">
                    <label>Medicamento (obligatorio)</label>
                    <select name="medicineId">
                        <option value="">Seleccione...</option>
                        @foreach (var m in meds)
                        {
                            <option value="@m.id">@m.name</option>
                        }
                    </select>
                </div>

                <div class="field">
                    <label>Dosis (obligatorio)</label>
                    <input name="dose" />
                </div>

                <div class="field" style="grid-column:1/-1;">
                    <label>Observaciones</label>
                    <textarea name="observations"></textarea>
                </div>
            </div>

            <div class="actions">
                <button class="btn primary" type="submit">Guardar (Ajax)</button>
                <a class="btn" href="@Url.Action("Details","Animals", new { id = animalId })">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section scripts{
    <script>
function showTMsg(t){ $("#tMsg").text(t).show(); }

$("#frmAddT").on("submit", function(e){
  e.preventDefault();
  $.ajax({
    url: "@Url.Action("AddJson","Treatments")",
    method: "POST",
    data: $(this).serialize(),
    success: function(r){
      if(r && r.ok){
        window.location = "@Url.Action("Details","Animals", new { id = animalId })";
      } else {
        showTMsg((r && r.msg) ? r.msg : "No se pudo guardar.");
      }
    },
    error: function(){ showTMsg("Error servidor."); }
  });
});
    </script>
}